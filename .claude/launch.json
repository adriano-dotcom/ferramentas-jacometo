{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "jarvis-bot",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "src/index.js"],
      "port": 3001
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 3000
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "backend",
      "port": 3001
    }
  ]
}
