# ══════════════════════════════════════════════════════
#  Ferramentas Jacometo — Backend .env
#  Mac Mini Jarvis — ~/ferramentas-jacometo/backend/
#  Senhas das seguradoras: /ferramentas/configuracoes
# ══════════════════════════════════════════════════════

# ── Servidor
PORT=3001
FRONTEND_URL=https://ferramentas.jacometo.com.br

# ── Playwright
HEADLESS=true
DOWNLOAD_DIR=./downloads

# ── Email (Gmail App Password)
# Gerar em: myaccount.google.com > Segurança > Senhas de App
SMTP_USER=automacao@jacometo.com.br
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_EQUIPE=adriano@jacometo.com.br,giovana@jacometo.com.br,joao@jacometo.com.br,barbara@jacometo.com.br

# ── Google Drive / Sheets
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_DRIVE_FOLDER_BOLETOS=1gj4sSwnG9syz5nbKN8WnjRuNL_20vnUA
GOOGLE_SHEETS_GRUPOS_ID=1fDJV0GKWr2jNfxwOJiLBhqCsATidFjIo

# ── Supabase (histórico de jobs + clientes Plano Hospitalar)
# Pegar em: supabase.com > projeto > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Criptografia do painel de credenciais (AES-256 — 32 chars, não mudar depois)
# Gerar: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CONFIG_ENCRYPT_KEY=mude-isso-para-32-chars-aleatorios
